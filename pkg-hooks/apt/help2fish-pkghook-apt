#!/usr/bin/env python3
"""
help2fish apt bridge — best-effort. apt/dpkg do not hand us the changed binaries
directly, so we read the most recent install/upgrade actions from
/var/log/dpkg.log, resolve each package's files with `dpkg -L`, keep the ones in
bin/sbin dirs, and feed them to help2fish-pkghook.
"""
import os
import re
import subprocess
import sys
import time

HERE = os.path.dirname(os.path.abspath(__file__))
PKGHOOK = os.environ.get("HELP2FISH_PKGHOOK",
                         "/usr/local/share/help2fish/help2fish-pkghook")
DPKG_LOG = "/var/log/dpkg.log"
WINDOW_SECONDS = 600  # only packages touched in the last 10 minutes

LINE = re.compile(r"^(\S+ \S+) (?:install|upgrade|configure) (\S+?)(?::\S+)? ")


def recent_packages():
    pkgs = []
    now = time.time()
    try:
        with open(DPKG_LOG, errors="ignore") as f:
            for ln in f:
                m = LINE.match(ln)
                if not m:
                    continue
                try:
                    ts = time.mktime(time.strptime(m.group(1), "%Y-%m-%d %H:%M:%S"))
                except ValueError:
                    continue
                if now - ts <= WINDOW_SECONDS:
                    pkgs.append(m.group(2))
    except OSError:
        return []
    # dedupe preserving order
    seen, out = set(), []
    for p in pkgs:
        if p not in seen:
            seen.add(p)
            out.append(p)
    return out


def bin_files(pkg):
    try:
        r = subprocess.run(["dpkg", "-L", pkg], capture_output=True, text=True, timeout=15)
    except (OSError, subprocess.TimeoutExpired):
        return []
    out = []
    for ln in r.stdout.splitlines():
        p = ln.strip()
        if ("/bin/" in p or "/sbin/" in p) and os.path.isfile(p) and os.access(p, os.X_OK):
            out.append(p)
    return out


def main():
    paths = []
    for pkg in recent_packages():
        paths += bin_files(pkg)
    if not paths:
        return 0
    if not os.path.exists(PKGHOOK):
        print(f"help2fish: pkghook not found at {PKGHOOK}", file=sys.stderr)
        return 1
    subprocess.run([sys.executable, PKGHOOK] + paths)
    return 0


if __name__ == "__main__":
    sys.exit(main())
